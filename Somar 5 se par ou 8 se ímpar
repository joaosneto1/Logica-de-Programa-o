import java.util.Scanner;

public class Ex7 {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int numero;

        System.out.print("Digite um número: ");
        numero = sc.nextInt();

        if (numero % 2 == 0) {
            numero += 5;
        } else {
            numero += 8;
        }

        System.out.println("Resultado: " + numero);

        sc.close();
    }
}
