package faculdade
import java.util.Scanner;

public class Ex5 {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int numero;

        System.out.print("Digite um número: ");
        numero = sc.nextInt();

        if (numero >= 0) {
            System.out.println("Dobro: " + (numero * 2));
        } else {
            System.out.println("Triplo: " + (numero * 3));
        }

        sc.close();
    }
}
